{
  "name": "@app/source",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "dev": "nx run api:serve & nx run web:serve",
    "dev:parallel": "nx run-many --target=serve --projects=api,web --parallel",
    "dev:web": "nx serve web",
    "dev:api": "nx serve api",
    "build:web": "nx build web",
    "build:api": "nx build api",
    "lint": "nx run-many --target=lint",
    "test": "nx run-many --target=test",
    "db:migrate": "cd apps/api && npx prisma migrate dev",
    "db:seed": "nx run api:db-seed",
    "db:seed:reset": "nx run api:db-fresh",
    "db:reset": "nx run api:db-reset",
    "db:fresh": "nx run api:db-fresh",
    "db:generate": "npx prisma generate --schema=apps/api/prisma/schema.prisma"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@prisma/client": "^5.10.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "axios": "^1.7.4",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.441.0",
    "next": "^15.3.0",
    "next-themes": "^0.4.6",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "tailwind-merge": "^2.5.2",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nx/eslint": "^20.0.0",
    "@nx/eslint-plugin": "^20.0.0",
    "@nx/js": "^20.0.0",
    "@nx/nest": "^20.0.0",
    "@nx/next": "^20.0.0",
    "@nx/node": "^20.0.0",
    "@nx/webpack": "^20.0.0",
    "@swc-node/register": "^1.10.9",
    "@swc/core": "^1.15.33",
    "@swc/helpers": "^0.5.15",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.10.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "nx": "^20.0.0",
    "postcss": "^8.4.45",
    "prettier": "^3.3.3",
    "prisma": "^5.10.0",
    "tailwindcss": "^3.4.10",
    "ts-node": "^10.9.2",
    "typescript": "~5.5.2"
  },
  "trustedDependencies": [
    "@nestjs/core",
    "@parcel/watcher",
    "@swc/core"
  ]
}